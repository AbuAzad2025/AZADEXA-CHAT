{
  "name": "zestchat",
  "private": true,
  "version": "0.1.0",
  "description": "ZestChat - Global chat platform for teens and young adults",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @zestchat/web run test:e2e",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "pnpm@9.4.0",
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
